<?php

/**
 * Implements hook_entity_info().
 */
function annotation_entity_info() {
  return array(
    'annotation' => array(
      'label' => t('Annotation'),
      'base table' => 'annotation',
      'entity class' => 'Annotation',
      'controller class' => 'EntityDatabaseStorageController',
      'fieldable' => FALSE,
      'entity keys' => array(
        'id' => 'aid',
        'label' => 'label',
      ),
      'module' => 'annotation',
      'autoload' => array(
        'Annotation' => 'annotation.entity.inc',
      ),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function annotation_menu() {
  $items = array();

  $items['annotation/save'] = array(
    'title' => 'Save Annotation',
    'page callback' => 'annotation_save_callback',
    'access callback' => TRUE, // Add real permission check!
    'type' => MENU_CALLBACK,
    'delivery callback' => 'backdrop_json_deliver',
  );

  $items['annotation/load'] = array(
    'page callback' => 'annotation_load_endpoint',
    'access callback' => TRUE,
    'type' => MENU_CALLBACK,
  );

  return $items;
}

function annotation_save_callback() {
  $data = json_decode(file_get_contents('php://input'), TRUE);

  if (empty($data['body']) || empty($data['target'])) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Missing fields']);
    backdrop_exit();
  }

  $annotation = entity_create('annotation', array(
    'body' => $data['body'],
    'target' => $data['target'],
    'start' => intval($data['start']),
    'end' => intval($data['end']),
    'created' => REQUEST_TIME,
  ));
  $annotation->save();

  backdrop_add_http_header('Content-Type', 'application/json');
  echo json_encode(['status' => 'success', 'id' => $annotation->aid]);
  backdrop_exit();
}

function annotation_load_endpoint() {
  backdrop_add_http_header('Content-Type', 'application/json');

  $annotations = entity_load_multiple('annotation', FALSE, [], ['created' => 'DESC'], 0, 100);
  $output = [];

  foreach ($annotations as $a) {
    $output[] = [
      'body' => [
        [
          'type' => 'TextualBody',
          'value' => $a->body,
          'purpose' => 'commenting',
        ]
      ],
      'target' => [
        'selector' => [
          [
            'type' => 'TextPositionSelector',
            'start' => (int) $a->start,
            'end' => (int) $a->end,
          ],
          [
            'type' => 'TextQuoteSelector',
            'exact' => $a->target,
          ]
        ]
      ]
    ];
  }

  echo json_encode($output);
  backdrop_exit();
}

/**
 * Implements hook_autoload_info().
 */
function annotation_autoload_info() {
  return array(
    'Annotation' => 'includes/annotation.entity.inc',
  );
}

/**
 * Implements hook_library_info().
 */
function annotation_library_info() {
  $module_path = backdrop_get_path('module', 'annotation');

  $libraries['recogito'] = array(
    'title' => 'RecogitoJS',
    'version' => '1.8.4',
    'js' => array(
      $module_path . '/js/recogito.min.js' => array(
        'type' => 'file',
        'minified' => TRUE,
      ),
    ),
    'css' => array(
      $module_path . '/css/recogito.min.css' => array(
        'type' => 'file',
        'media' => 'all',
        'preprocess' => FALSE,
      ),
    ),
  );

  $libraries['recogito_integration'] = array(
    'title' => 'RecogitoJS Integration',
    'version' => '1.0',
    'js' => array(
      $module_path . '/js/recogito-integration.js' => array(),
    ),
    'dependencies' => array(
      array('annotation', 'recogito'),
    ),
  );

  return $libraries;
}

