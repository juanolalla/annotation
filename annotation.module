/**
 * Implements hook_library_info().
 */
function annotation_library_info() {
  $module_path = backdrop_get_path('module', 'annotation');

  $libraries['recogito'] = array(
    'title' => 'RecogitoJS',
    'version' => '1.8.4',
    'js' => array(
      $module_path . '/js/recogito.min.js' => array(
        'type' => 'file',
        'minified' => TRUE,
      ),
    ),
    'css' => array(
      $module_path . '/css/recogito.min.css' => array(
        'type' => 'file',
        'media' => 'all',
        'preprocess' => FALSE,
      ),
    ),
  );

  $libraries['recogito_integration'] = array(
    'title' => 'RecogitoJS Integration',
    'version' => '1.0',
    'js' => array(
      $module_path . '/js/recogito-integration.js' => array('weight' => 1),
      $module_path . '/js/recogito-hide-replies.js' => array('weight' => 2),
    ),
    'dependencies' => array(
      array('annotation', 'recogito'),
    ),
  );

  return $libraries;
}


/**
 * Implements hook_init().
 */
function annotation_init() {
  // Attach Recogito and preload annotations for users who can manage or view them.
  $can_admin = user_access('administer annotations');
  $can_edit_own = user_access('edit own annotations');
  $can_view = user_access('view annotations');
  if (!$can_admin && !$can_edit_own && !$can_view) {
    return;
  }

  backdrop_add_library('annotation', 'recogito_integration');

  // Determine selector from configuration with a sensible default.
  $config = config('annotation.settings');
  $selector = $config->get('selector');
  if (!$selector) {
    $selector = '.node';
  }

  // Load annotations for the current URL and filter by permissions.
  $path = parse_url(request_uri(), PHP_URL_PATH);

  $aids = array();
  if (!empty($path)) {
    $query = new EntityFieldQuery();
    $query->entityCondition('entity_type', 'annotation')
      ->propertyCondition('url', $path);
    // If the user cannot administer all annotations, and cannot view all, but has edit own, restrict to own.
    if (!$can_admin && !$can_view && $can_edit_own && !empty($GLOBALS['user']->uid)) {
      $query->propertyCondition('uid', (int) $GLOBALS['user']->uid);
    }
    $result = $query->execute();
    if (!empty($result['annotation'])) {
      $aids = array_keys($result['annotation']);
    }
  }

  $annotations = $aids ? entity_load('annotation', $aids) : array();

  $json = [];

  foreach ($annotations as $annotation) {
    // Decode selectors as saved for preloading
    $selectors = [];
    if (!empty($annotation->selectors)) {
      $decoded = json_decode($annotation->selectors, TRUE);
      if (is_array($decoded)) {
        $selectors = array_values($decoded);
      }
    }

    if (empty($selectors)) {
      // Skip invalid annotations lacking selectors.
      continue;
    }

    $account = user_load($annotation->uid);
    $json[] = array(
      'id' => (string) $annotation->aid,
      'type' => 'Annotation',
      'body' => array(
        array(
          'type' => 'TextualBody',
          'value' => $annotation->body,
          'purpose' => 'commenting',
        ),
      ),
      'target' => array(
        'selector' => $selectors,
      ),
      'creator' => array(
        'id' => (int) $annotation->uid,
        'name' => $account ? format_username($account) : ''
      ),
    );
  }

  // Provide annotations and selector via Backdrop settings for the frontend behavior.
  // Expose minimal permission flags so the frontend can switch Recogito to read-only.
  $can_create = user_access('create annotations');
  $settings = array(
    'recogito' => array(
      'annotations' => $json,
      'selector' => $selector,
      'permissions' => array(
        'canAdmin' => (bool) $can_admin,
        'canEditOwn' => (bool) $can_edit_own,
        'canCreate' => (bool) $can_create,
        'readOnly' => (!$can_admin && !$can_edit_own && !$can_create),
      ),
      'currentUser' => array(
        'id' => !empty($GLOBALS['user']->uid) ? (int) $GLOBALS['user']->uid : 0,
        'name' => !empty($GLOBALS['user']->uid) ? format_username($GLOBALS['user']) : '',
      ),
    ),
  );
  backdrop_add_js($settings, array('type' => 'setting'));
}

/**
 * Menu loader for %annotation to load an Annotation entity by ID.
 */
function annotation_load($aid) {
  $aid = (int) $aid;
  if (!$aid) {
    return FALSE;
  }
  $list = entity_load('annotation', array($aid));
  return $list ? reset($list) : FALSE;
}

/**
 * Access checks.
 */
function annotation_access_view($annotation) {
  global $user;
  // Allow admins, or owners who have the view permission.
  if (user_access('administer annotations')) {
    return TRUE;
  }
  return user_access('view annotations') && (!empty($user->uid) && (int) $user->uid === (int) $annotation->uid);
}
function annotation_access_edit($annotation) {
  global $user;
  if (user_access('administer annotations')) {
    return TRUE;
  }
  // Require explicit permission to edit own, and ownership.
  return user_access('edit own annotations') && (!empty($user->uid) && (int) $user->uid === (int) $annotation->uid);
}
function annotation_access_delete($annotation) {
  global $user;
  if (user_access('administer annotations')) {
    return TRUE;
  }
  // Require explicit permission to edit own (same as delete own), and ownership.
  return user_access('edit own annotations') && (!empty($user->uid) && (int) $user->uid === (int) $annotation->uid);
}

/**
 * Title callback for annotation pages.
 */
function annotation_page_title($annotation) {
  return t('Annotation @id', array('@id' => $annotation->aid));
}

/**
 * Extract first available TextQuoteSelector exact quote from selectors JSON.
 */
function annotation_extract_quote($annotation) {
  if (empty($annotation->selectors)) {
    return '';
  }
  $decoded = json_decode($annotation->selectors, TRUE);
  if (!is_array($decoded)) {
    return '';
  }
  foreach ($decoded as $sel) {
    if (is_array($sel)) {
      // W3C Web Annotation format often has type TextQuoteSelector
      if (!empty($sel['type']) && $sel['type'] === 'TextQuoteSelector' && !empty($sel['exact'])) {
        return $sel['exact'];
      }
      // Some clients may nest under 'selector' field
      if (!empty($sel['selector']) && is_array($sel['selector'])) {
        foreach ($sel['selector'] as $inner) {
          if (!empty($inner['type']) && $inner['type'] === 'TextQuoteSelector' && !empty($inner['exact'])) {
            return $inner['exact'];
          }
        }
      }
    }
  }
  return '';
}

/**
 * View page callback for an annotation.
 */
function annotation_view_page($annotation) {
  $account = user_load($annotation->uid);
  $quote = annotation_extract_quote($annotation);
  $rows = array();
  $rows[] = array(array('data' => t('Annotation text'), 'header' => TRUE), check_plain($annotation->body));
  $rows[] = array(array('data' => t('Quote'), 'header' => TRUE), check_plain($quote));
  $rows[] = array(array('data' => t('URI'), 'header' => TRUE), l(check_plain($annotation->url), $annotation->url, array('attributes' => array('target' => '_blank'))));
  $rows[] = array(array('data' => t('Author'), 'header' => TRUE), theme('username', array('account' => $account)));
  $rows[] = array(array('data' => t('Updated'), 'header' => TRUE), format_date($annotation->created, 'medium'));

  $build = array();
  $build['annotation_table'] = array(
    '#theme' => 'table',
    '#rows' => $rows,
    '#header' => array(),
  );
  return $build;
}

/**
 * Edit form for an annotation.
 */
function annotation_edit_form($form, &$form_state, $annotation) {
  $form['body'] = array(
    '#type' => 'textarea',
    '#title' => t('Annotation text'),
    '#default_value' => $annotation->body,
    '#required' => TRUE,
  );

  $form['aid'] = array('#type' => 'value', '#value' => $annotation->aid);

  $form['actions'] = array('#type' => 'actions');
  $form['actions']['submit'] = array(
    '#type' => 'submit',
    '#value' => t('Save'),
  );

  return $form;
}
function annotation_edit_form_submit($form, &$form_state) {
  $aid = (int) $form_state['values']['aid'];
  $list = entity_load('annotation', array($aid));
  $annotation = $list ? reset($list) : NULL;
  if (!$annotation) {
    backdrop_set_message(t('Annotation not found.'), 'error');
    $form_state['redirect'] = 'admin/content/annotation';
    return;
  }
  $annotation->body = (string) $form_state['values']['body'];
  $annotation->save();
  backdrop_set_message(t('Annotation has been saved.'));
  $form_state['redirect'] = 'annotation/' . $annotation->aid;
}

/**
 * Delete confirmation form for an annotation.
 */
function annotation_delete_form($form, &$form_state, $annotation) {
  $form['aid'] = array('#type' => 'value', '#value' => $annotation->aid);
  return confirm_form(
    $form,
    t('Are you sure you want to delete annotation @id?', array('@id' => $annotation->aid)),
    'annotation/' . $annotation->aid,
    t('This action cannot be undone.'),
    t('Delete'),
    t('Cancel')
  );
}
function annotation_delete_form_submit($form, &$form_state) {
  $aid = (int) $form_state['values']['aid'];
  $list = entity_load('annotation', array($aid));
  $annotation = $list ? reset($list) : NULL;
  if ($annotation) {
    $annotation->delete();
    backdrop_set_message(t('Annotation has been deleted.'));
  }
  $form_state['redirect'] = 'admin/content/annotation';
}

/**
 * Admin listing page for annotations.
 */
function annotation_admin_overview() {
  $header = array(
    array('data' => t('Annotation text')),
    array('data' => t('Quote')),
    array('data' => t('URI')),
    array('data' => t('Author')),
    array('data' => t('Updated')),
    array('data' => t('Operations')),
  );

  $rows = array();

  $query = db_select('annotation', 'a')
    ->fields('a', array('aid', 'uid', 'url', 'body', 'selectors', 'created'))
    ->orderBy('created', 'DESC');
  $result = $query->execute();

  foreach ($result as $record) {
    // Build a temporary annotation entity-like object for helpers.
    $annotation = new stdClass();
    $annotation->aid = $record->aid;
    $annotation->uid = $record->uid;
    $annotation->url = $record->url;
    $annotation->body = $record->body;
    $annotation->selectors = $record->selectors;
    $annotation->created = $record->created;

    $account = user_load($annotation->uid);
    $quote = annotation_extract_quote($annotation);

    $ops = array();
    $ops[] = l(t('View'), 'annotation/' . $annotation->aid);
    $ops[] = l(t('Edit'), 'annotation/' . $annotation->aid . '/edit');
    $ops[] = l(t('Delete'), 'annotation/' . $annotation->aid . '/delete');

    $rows[] = array(
      check_plain($annotation->body),
      check_plain($quote),
      l(check_plain($annotation->url), $annotation->url, array('attributes' => array('target' => '_blank'))),
      theme('username', array('account' => $account)),
      format_date($annotation->created, 'medium'),
      array('data' => implode(' | ', $ops)),
    );
  }

  $build['annotations'] = array(
    '#theme' => 'table',
    '#header' => $header,
    '#rows' => $rows,
    '#empty' => t('No annotations found.'),
  );

  return $build;
}
