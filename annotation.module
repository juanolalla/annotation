<?php

/**
 * Implements hook_entity_info().
 */
function annotation_entity_info() {
  return array(
    'annotation' => array(
      'label' => t('Annotation'),
      'base table' => 'annotation',
      'entity class' => 'Annotation',
      'controller class' => 'EntityDatabaseStorageController',
      'fieldable' => FALSE,
      'entity keys' => array(
        'id' => 'aid',
        'label' => 'label',
      ),
      'module' => 'annotation',
      'autoload' => array(
        'Annotation' => 'annotation.entity.inc',
      ),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function annotation_menu() {
  $items = array();

  // Admin settings form for Recogito selector.
  $items['admin/config/content/annotation'] = array(
    'title' => 'Annotation settings',
    'description' => 'Configure the CSS selector Recogito uses to attach to page content.',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('annotation_admin_settings_form'),
    'access arguments' => array('administer site configuration'),
    'file' => 'annotation.admin.inc',
    'type' => MENU_NORMAL_ITEM,
  );

  $items['annotation/save'] = array(
    'title' => 'Save Annotation',
    'page callback' => 'annotation_save_callback',
    'access callback' => TRUE, // Access enforced in callback.
    'type' => MENU_CALLBACK,
    'delivery callback' => 'backdrop_json_deliver',
  );

  $items['annotation/load'] = array(
    'page callback' => 'annotation_load_endpoint',
    'access callback' => TRUE,
    'type' => MENU_CALLBACK,
  );

  $items['annotation/update'] = array(
    'title' => 'Update Annotation',
    'page callback' => 'annotation_update_callback',
    'access callback' => TRUE, // Access enforced in callback.
    'type' => MENU_CALLBACK,
    'delivery callback' => 'backdrop_json_deliver',
  );

  $items['annotation/delete'] = array(
    'title' => 'Delete Annotation',
    'page callback' => 'annotation_delete_callback',
    'access callback' => TRUE, // Access enforced in callback.
    'type' => MENU_CALLBACK,
    'delivery callback' => 'backdrop_json_deliver',
  );

  return $items;
}

function annotation_save_callback() {
  global $user;
  $data = json_decode(file_get_contents('php://input'), TRUE);

  // Only authenticated users can create annotations.
  if (empty($user) || empty($user->uid)) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Access denied']);
    backdrop_exit();
  }

  if (empty($data['url']) || !isset($data['body']) || !isset($data['selectors'])) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Missing fields']);
    backdrop_exit();
  }

  // Normalize selectors to JSON string
  $selectors = $data['selectors'];
  if (is_array($selectors)) {
    // Optionally filter out anything not an object with type field
    $selectors = json_encode(array_values($selectors));
  } else {
    // If client sent a string, trust it but ensure it's a string
    $selectors = (string) $selectors;
  }

  $annotation = entity_create('annotation', array(
    'uid' => (int) $user->uid,
    'url' => substr($data['url'], 0, 255),
    'body' => (string) $data['body'],
    'selectors' => $selectors,
    'created' => REQUEST_TIME,
  ));
  $annotation->save();

  backdrop_add_http_header('Content-Type', 'application/json');
  echo json_encode(['status' => 'success', 'id' => $annotation->aid]);
  backdrop_exit();
}

function annotation_load_endpoint() {
  global $user;
  backdrop_add_http_header('Content-Type', 'application/json');

  // Anonymous users cannot see annotations at all.
  if (empty($user) || empty($user->uid)) {
    echo json_encode([]); backdrop_exit();
  }

  $current_url = $_GET['url'] ?? '';
  if (empty($current_url)) {
    echo json_encode([]); backdrop_exit();
  }

  $query = new EntityFieldQuery();
  $query->entityCondition('entity_type', 'annotation')
    ->propertyCondition('url', $current_url)
    ->propertyCondition('uid', (int) $user->uid);

  $result = $query->execute();
  $aids = !empty($result['annotation']) ? array_keys($result['annotation']) : [];

  $annotations = entity_load('annotation', $aids);
  $output = [];

  foreach ($annotations as $a) {
    // Decode selectors as saved (keep order, include TextPositionSelector if present)
    $selectors = [];
    if (!empty($a->selectors)) {
      $decoded = json_decode($a->selectors, TRUE);
      if (is_array($decoded)) {
        $selectors = array_values($decoded);
      }
    }

    if (empty($selectors)) {
      // Nothing we can anchor on; skip this record to avoid loading invalid annotations.
      continue;
    }

    $output[] = [
      'id' => (string) $a->aid,
      'type' => 'Annotation',
      'body' => [
        [
          'type' => 'TextualBody',
          'value' => $a->body,
          'purpose' => 'commenting',
        ]
      ],
      'target' => [
        'selector' => $selectors
      ]
    ];
  }

  echo json_encode($output);
  backdrop_exit();
}

function annotation_update_callback() {
  global $user;
  $data = json_decode(file_get_contents('php://input'), TRUE);

  // Must be authenticated
  if (empty($user) || empty($user->uid)) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Access denied']);
    backdrop_exit();
  }

  $aid = isset($data['id']) ? intval($data['id']) : 0;
  if (!$aid) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Missing id']);
    backdrop_exit();
  }

  $annotations = entity_load('annotation', array($aid));
  $annotation = $annotations ? reset($annotations) : NULL;
  if (!$annotation) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Annotation not found']);
    backdrop_exit();
  }

  // Only owner can update
  if ((int) $annotation->uid !== (int) $user->uid) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Access denied']);
    backdrop_exit();
  }

  // Update allowed fields
  if (isset($data['body'])) {
    $annotation->body = (string) $data['body'];
  }
  if (isset($data['selectors'])) {
    $selectors = $data['selectors'];
    if (is_array($selectors)) {
      $selectors = json_encode(array_values($selectors));
    } else {
      $selectors = (string) $selectors;
    }
    $annotation->selectors = $selectors;
  }

  $annotation->save();

  backdrop_add_http_header('Content-Type', 'application/json');
  echo json_encode(['status' => 'success', 'id' => $annotation->aid]);
  backdrop_exit();
}

function annotation_delete_callback() {
  global $user;
  $data = json_decode(file_get_contents('php://input'), TRUE);

  // Must be authenticated
  if (empty($user) || empty($user->uid)) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Access denied']);
    backdrop_exit();
  }

  $aid = isset($data['id']) ? intval($data['id']) : 0;
  if (!$aid) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Missing id']);
    backdrop_exit();
  }

  $annotations = entity_load('annotation', array($aid));
  $annotation = $annotations ? reset($annotations) : NULL;
  if (!$annotation) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Annotation not found']);
    backdrop_exit();
  }

  // Only owner can delete
  if ((int) $annotation->uid !== (int) $user->uid) {
    backdrop_add_http_header('Content-Type', 'application/json');
    echo json_encode(['status' => 'error', 'message' => 'Access denied']);
    backdrop_exit();
  }

  $annotation->delete();

  backdrop_add_http_header('Content-Type', 'application/json');
  echo json_encode(['status' => 'success']);
  backdrop_exit();
}

/**
 * Implements hook_autoload_info().
 */
function annotation_autoload_info() {
  return array(
    'Annotation' => 'includes/annotation.entity.inc',
  );
}

/**
 * Implements hook_library_info().
 */
function annotation_library_info() {
  $module_path = backdrop_get_path('module', 'annotation');

  $libraries['recogito'] = array(
    'title' => 'RecogitoJS',
    'version' => '1.8.4',
    'js' => array(
      $module_path . '/js/recogito.min.js' => array(
        'type' => 'file',
        'minified' => TRUE,
      ),
    ),
    'css' => array(
      $module_path . '/css/recogito.min.css' => array(
        'type' => 'file',
        'media' => 'all',
        'preprocess' => FALSE,
      ),
    ),
  );

  $libraries['recogito_integration'] = array(
    'title' => 'RecogitoJS Integration',
    'version' => '1.0',
    'js' => array(
      $module_path . '/js/recogito-integration.js' => array('weight' => 1),
      $module_path . '/js/recogito-hide-replies.js' => array('weight' => 2),
    ),
    'dependencies' => array(
      array('annotation', 'recogito'),
    ),
  );

  return $libraries;
}


/**
 * Implements hook_init().
 */
function annotation_init() {
  global $user;

  // Do not attach Recogito for anonymous users.
  if (empty($user) || empty($user->uid)) {
    return;
  }

  backdrop_add_library('annotation', 'recogito_integration');

  // Determine selector from configuration with a sensible default.
  $config = config('annotation.settings');
  $selector = $config->get('selector');
  if (!$selector) {
    $selector = '.node';
  }

  // Load all annotations for the current URL (filter by URL, only for current user).
  $path = parse_url(request_uri(), PHP_URL_PATH);

  $aids = array();
  if (!empty($path)) {
    $query = new EntityFieldQuery();
    $query->entityCondition('entity_type', 'annotation')
      ->propertyCondition('url', $path)
      ->propertyCondition('uid', (int) $user->uid);
    $result = $query->execute();
    if (!empty($result['annotation'])) {
      $aids = array_keys($result['annotation']);
    }
  }

  $annotations = $aids ? entity_load('annotation', $aids) : array();

  $json = [];

  foreach ($annotations as $annotation) {
    // Decode selectors as saved for preloading
    $selectors = [];
    if (!empty($annotation->selectors)) {
      $decoded = json_decode($annotation->selectors, TRUE);
      if (is_array($decoded)) {
        $selectors = array_values($decoded);
      }
    }

    if (empty($selectors)) {
      // Skip invalid annotations lacking selectors.
      continue;
    }

    $json[] = array(
      'id' => (string) $annotation->aid,
      'type' => 'Annotation',
      'body' => array(
        array(
          'type' => 'TextualBody',
          'value' => $annotation->body,
          'purpose' => 'commenting',
        ),
      ),
      'target' => array(
        'selector' => $selectors,
      ),
    );
  }

  // Provide annotations and selector via Backdrop settings for the frontend behavior.
  backdrop_add_js(array('recogito' => array('annotations' => $json, 'selector' => $selector)), array('type' => 'setting'));
}
